-- ==================== LÓGICA DEL CHEAT ====================
local connection
connection = RunService.RenderStepped:Connect(function()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local char = player.Character
    local hum = char:FindFirstChild("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    
    if not hum or not root then return end

    -- Speed
    hum.WalkSpeed = getgenv().Brainrot.Speed

    -- AimBot (Cam Lock - muy fuerte)
    if getgenv().Brainrot.AimBot then
        local closest = nil
        local shortest = math.huge
        
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and plr.Character and plr.Character:FindFirstChild("Head") then
                local head = plr.Character.Head
                local distance = (head.Position - camera.CFrame.Position).Magnitude
                if distance < shortest and distance < 400 then
                    shortest = distance
                    closest = head
                end
            end
        end
        
        if closest then
            camera.CFrame = CFrame.lookAt(camera.CFrame.Position, closest.Position)
        end
    end

    -- AutoSteal (roba herramientas y objetos cercanos)
    if getgenv().Brainrot.AutoSteal then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Tool") or obj:IsA("Accessory") then
                if obj.Parent ~= char and (obj:FindFirstChild("Handle") or obj:FindFirstChild("PrimaryPart")) then
                    local handle = obj:FindFirstChild("Handle") or obj.PrimaryPart
                    if handle and (handle.Position - root.Position).Magnitude < 40 then
                        obj.Parent = char
                    end
                end
            end
        end
    end

    -- AntiRagdoll
    if getgenv().Brainrot.AntiRagdoll then
        hum.PlatformStand = false
        hum.Sit = false
        hum:ChangeState(Enum.HumanoidStateType.Running)
        if hum:FindFirstChild("Ragdolled") then hum.Ragdolled.Value = false end
    end

    -- Auto TP Down (teletransporta al suelo automáticamente)
    if getgenv().Brainrot.AutoTPDown then
        local ray = Ray.new(root.Position, Vector3.new(0, -500, 0))
        local hit, pos = workspace:FindPartOnRayWithIgnoreList(ray, {char})
        if hit and pos then
            root.CFrame = CFrame.new(pos + Vector3.new(0, 4, 0))
        end
    end

    -- Auto Strafe (izquierda ↔ derecha automático)
    if getgenv().Brainrot.AutoStrafe then
        local t = tick() * 12
        local direction = Vector3.new(math.sin(t) * 60, 0, 0)
        root.Velocity = Vector3.new(direction.X, root.Velocity.Y, direction.Z)
    end

    -- Drop Brainrot (dropea todo + mensaje brainrot)
    if getgenv().Brainrot.DropBrainrot then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") then
                tool.Parent = workspace
            end
        end
        -- Mensaje brainrot en chat (opcional)
        game.ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer("🧠 BRAINROT DROP ACTIVADO 🧠", "All")
        getgenv().Brainrot.DropBrainrot = false -- se apaga solo después de dropear
    end
end)

