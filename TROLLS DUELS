-- Función para crear toggles bonitos
local function CreateToggle(name, posY, default)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(0.9, 0, 0, 45)
    ToggleFrame.Position = UDim2.new(0.05, 0, 0, posY)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    ToggleFrame.Parent = MainFrame
    local TCorner = Instance.new("UICorner"); TCorner.CornerRadius = UDim.new(0, 10); TCorner.Parent = ToggleFrame

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.7, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.TextScaled = true
    Label.Font = Enum.Font.GothamSemibold
    Label.Parent = ToggleFrame

    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(0.25, 0, 0.7, 0)
    Button.Position = UDim2.new(0.72, 0, 0.15, 0)
    Button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    Button.Text = "OFF"
    Button.TextColor3 = Color3.fromRGB(255, 50, 50)
    Button.TextScaled = true
    Button.Font = Enum.Font.GothamBold
    Button.Parent = ToggleFrame
    local BCorner = Instance.new("UICorner"); BCorner.CornerRadius = UDim.new(0, 8); BCorner.Parent = Button

    local toggled = default or false
    Button.MouseButton1Click:Connect(function()
        toggled = not toggled
        getgenv().Brainrot[name] = toggled
        
        if toggled then
            Button.Text = "ON"
            Button.TextColor3 = Color3.fromRGB(0, 255, 100)
            Button.BackgroundColor3 = Color3.fromRGB(0, 100, 0)
        else
            Button.Text = "OFF"
            Button.TextColor3 = Color3.fromRGB(255, 50, 50)
            Button.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end
    end)
    
    return ToggleFrame
end

